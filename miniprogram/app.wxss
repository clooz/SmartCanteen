/* ===== SmartCanteen 全局设计系统（与今日菜单页统一）=====
   冷灰底 + Teal 主色，克制渐变与投影 */

page {
  --color-primary: #0f766e;
  --color-primary-mid: #14b8a6;
  --color-primary-light: rgba(13, 148, 136, 0.1);
  --color-primary-dark: #0d9488;
  --color-bg: #f0f4f8;
  --color-bg-soft: #eef1f6;
  --color-surface: #ffffff;
  --color-text: #111827;
  --color-text-secondary: #6b7280;
  --color-border: rgba(15, 23, 42, 0.06);
  --color-border-strong: #e5e7eb;
  --color-success: #16a34a;
  --color-success-light: #dcfce7;
  --color-warning: #d97706;
  --color-warning-light: #fef3c7;
  --color-error: #dc2626;
  --color-error-light: #fee2e2;
  --gradient-primary: linear-gradient(125deg, #5eead4 0%, #2dd4bf 38%, #14b8a6 72%, #0d9488 100%);
  --gradient-hero: linear-gradient(155deg, #5eead4 0%, #2dd4bf 32%, #14b8a6 62%, #0d9488 100%);

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-xl: 24rpx;
  --radius-full: 9999rpx;

  --shadow-sm: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
  --shadow-md: 0 4rpx 20rpx rgba(15, 23, 42, 0.06);

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
}

.flex {
  display: flex;
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.items-center {
  align-items: center;
}
.justify-center {
  justify-content: center;
}
.justify-between {
  justify-content: space-between;
}
.flex-1 {
  flex: 1;
}
.text-center {
  text-align: center;
}
.text-primary {
  color: var(--color-primary);
}
.text-secondary {
  color: var(--color-text-secondary);
}
.font-bold {
  font-weight: 700;
}
.font-medium {
  font-weight: 500;
}

.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
}

.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 32rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
}
.status-badge.pending {
  background: var(--color-warning-light);
  color: var(--color-warning);
}
.status-badge.success {
  background: var(--color-success-light);
  color: var(--color-success);
}
.status-badge.error {
  background: var(--color-error-light);
  color: var(--color-error);
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-primary);
  color: #fff;
  border-radius: var(--radius-full);
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  letter-spacing: 1rpx;
  box-shadow: 0 10rpx 28rpx rgba(13, 148, 136, 0.22);
}
.btn-primary:active {
  opacity: 0.9;
}

.divider {
  height: 1rpx;
  background: var(--color-border-strong);
  margin: 0 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--color-text-secondary);
}
.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}
.empty-state .empty-text {
  font-size: 28rpx;
  text-align: center;
  line-height: 1.8;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}
