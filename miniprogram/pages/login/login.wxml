<view class="login-page">
  <view class="brand-area">
    <view class="brand-logo">🍱</view>
    <view class="brand-name">智慧食堂</view>
    <view class="brand-slogan">好吃不将就，每天都有新惊喜</view>
  </view>

  <view class="tab-bar">
    <view class="tab-item {{mode === 'password' ? 'active' : ''}}" bindtap="switchMode" data-mode="password">邮箱登录</view>
    <view class="tab-item {{mode === 'sms' ? 'active' : ''}}" bindtap="switchMode" data-mode="sms">手机登录</view>
    <view class="tab-indicator" style="transform: translateX({{mode === 'password' ? '0' : '100%'}})"></view>
  </view>

  <view class="form-card">
    <block wx:if="{{mode === 'password'}}">
      <view class="form-field">
        <view class="field-label">邮箱</view>
        <input class="field-input" type="text" placeholder="请输入登录邮箱"
          value="{{email}}" bindinput="onInput" data-key="email"
          placeholder-class="field-placeholder" />
      </view>
      <view class="form-divider"></view>
      <view class="form-field">
        <view class="field-label">密码</view>
        <input class="field-input" password placeholder="请输入密码"
          value="{{password}}" bindinput="onInput" data-key="password"
          placeholder-class="field-placeholder" />
      </view>
    </block>
    <block wx:else>
      <view class="form-field">
        <view class="field-label">手机号</view>
        <input class="field-input" type="number" maxlength="11" placeholder="11 位手机号"
          value="{{phone}}" bindinput="onInput" data-key="phone"
          placeholder-class="field-placeholder" />
      </view>
      <view class="form-divider"></view>
      <view class="form-field form-field--row">
        <view class="field-grow">
          <view class="field-label">验证码</view>
          <input class="field-input" type="number" maxlength="6" placeholder="短信验证码"
            value="{{smsCode}}" bindinput="onInput" data-key="smsCode"
            placeholder-class="field-placeholder" />
        </view>
        <view class="sms-btn {{countdown > 0 || loading ? 'disabled' : ''}}" bindtap="sendSms">
          {{countdown > 0 ? countdown + 's' : '获取验证码'}}
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{showLegalRow}}" class="legal-row" bindtap="toggleAgree">
    <view class="legal-check {{agreed ? 'on' : ''}}">
      <text wx:if="{{agreed}}">✓</text>
    </view>
    <view class="legal-text">
      我已阅读并同意
      <navigator class="legal-link" url="/pages/legal/user-agreement/user-agreement">《用户协议》</navigator>
      与
      <navigator class="legal-link" url="/pages/legal/privacy-policy/privacy-policy">《隐私政策》</navigator>
    </view>
  </view>

  <view class="submit-wrap">
    <button class="btn-submit {{loading ? 'loading' : ''}}" bindtap="onSubmit" disabled="{{loading}}">
      <view wx:if="{{loading}}" class="btn-loading">
        <van-loading size="32rpx" color="#fff" />
      </view>
      <text wx:else>登录</text>
    </button>
  </view>

  <view class="forgot-wrap">
    <text class="forgot-link" bindtap="goForgot">忘记密码？</text>
  </view>
</view>
