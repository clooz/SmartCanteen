<view class="login-page">
  <!-- 顶部品牌区 -->
  <view class="brand-area">
    <view class="brand-logo">🍱</view>
    <view class="brand-name">智慧食堂</view>
    <view class="brand-slogan">好吃不将就，每天都有新惊喜</view>
  </view>

  <!-- Tab 切换：登录 / 注册 -->
  <view class="tab-bar">
    <view class="tab-item {{mode === 'login' ? 'active' : ''}}" bindtap="switchMode" data-mode="login">登录</view>
    <view class="tab-item {{mode === 'register' ? 'active' : ''}}" bindtap="switchMode" data-mode="register">注册</view>
    <view class="tab-indicator" style="transform: translateX({{mode === 'login' ? '0' : '100%'}})"></view>
  </view>

  <!-- 表单区 -->
  <view class="form-card">
    <!-- 注册时选公司 -->
    <view wx:if="{{mode === 'register'}}" class="form-field" bindtap="showCompanyPicker">
      <view class="field-label">所在公司</view>
      <view class="field-value {{selectedCompany ? '' : 'placeholder'}}">
        {{selectedCompany ? selectedCompany.name : '请选择公司'}}
      </view>
      <view class="field-arrow">›</view>
    </view>

    <view class="form-field">
      <view class="field-label">用户名</view>
      <input class="field-input" type="text" placeholder="请输入用户名"
        value="{{username}}" bindinput="onInput" data-key="username"
        placeholder-class="field-placeholder" />
    </view>

    <view class="form-divider"></view>

    <view wx:if="{{mode === 'register'}}" class="form-field">
      <view class="field-label">昵称</view>
      <input class="field-input" type="text" placeholder="请输入真实姓名（可选）"
        value="{{nickname}}" bindinput="onInput" data-key="nickname"
        placeholder-class="field-placeholder" />
    </view>

    <view wx:if="{{mode === 'register'}}" class="form-divider"></view>

    <view class="form-field">
      <view class="field-label">密码</view>
      <input class="field-input" password placeholder="请输入密码"
        value="{{password}}" bindinput="onInput" data-key="password"
        placeholder-class="field-placeholder" />
    </view>

    <view wx:if="{{mode === 'register'}}" class="form-divider"></view>

    <view wx:if="{{mode === 'register'}}" class="form-field">
      <view class="field-label">确认密码</view>
      <input class="field-input" password placeholder="再次输入密码"
        value="{{confirmPassword}}" bindinput="onInput" data-key="confirmPassword"
        placeholder-class="field-placeholder" />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-wrap">
    <button class="btn-submit {{loading ? 'loading' : ''}}" bindtap="onSubmit" disabled="{{loading}}">
      <view wx:if="{{loading}}" class="btn-loading">
        <van-loading size="32rpx" color="#fff" />
      </view>
      <text wx:else>{{mode === 'login' ? '登录' : '注册'}}</text>
    </button>
  </view>

  <!-- HR同步提示 -->
  <view wx:if="{{mode === 'register'}}" class="tip-text">
    如果公司已开通人事系统对接，账号由管理员统一创建，<text class="text-primary" bindtap="switchToLogin">直接登录</text>即可
  </view>

  <!-- 公司选择弹窗 -->
  <van-popup show="{{showPicker}}" position="bottom" bind:close="hidePicker" round>
    <view class="picker-header">
      <view class="picker-cancel" bindtap="hidePicker">取消</view>
      <view class="picker-title">选择公司</view>
      <view class="picker-confirm" bindtap="confirmCompany">确认</view>
    </view>
    <scroll-view scroll-y class="picker-list" enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{companies}}"
        wx:key="id"
        class="picker-item {{selectedCompanyIndex === index ? 'active' : ''}}"
        bindtap="selectCompanyItem"
        data-index="{{index}}"
      >
        {{item.name}}
        <van-icon wx:if="{{selectedCompanyIndex === index}}" name="success" color="#0F766E" size="36rpx" />
      </view>
    </scroll-view>
  </van-popup>
</view>
