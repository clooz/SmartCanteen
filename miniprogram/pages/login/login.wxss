.login-page {
  min-height: 100vh;
  background: linear-gradient(165deg, #eef1f6 0%, #f5f7fa 45%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  padding: 0 40rpx 60rpx;
}

.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 56rpx;
}

.brand-logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 16rpx rgba(15, 23, 42, 0.08));
}

.brand-name {
  font-size: 50rpx;
  font-weight: 700;
  color: #0f766e;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
}

.brand-slogan {
  font-size: 26rpx;
  color: #9ca3af;
  letter-spacing: 0.5rpx;
}

.tab-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 48rpx;
  padding: 5rpx;
  margin-bottom: 28rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.tab-indicator {
  position: absolute;
  top: 5rpx;
  left: 5rpx;
  width: calc(50% - 5rpx);
  bottom: 5rpx;
  background: linear-gradient(125deg, #2dd4bf, #14b8a6, #0d9488);
  border-radius: 40rpx;
  transition: transform 0.25s ease;
  z-index: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #9ca3af;
  position: relative;
  z-index: 1;
  transition: color 0.25s;
}

.tab-item.active {
  color: #ffffff;
}

.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.05);
  overflow: hidden;
  margin-bottom: 28rpx;
}

.form-field {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx;
  min-height: 100rpx;
}

.form-divider {
  height: 1rpx;
  background: #f3f4f6;
  margin: 0 32rpx;
}

.field-label {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  width: 140rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
  border: none;
  outline: none;
  background: transparent;
}

.field-placeholder {
  color: #d1d5db;
}

.field-value {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
}

.field-value.placeholder {
  color: #d1d5db;
}

.field-arrow {
  font-size: 40rpx;
  color: #d1d5db;
  margin-left: 8rpx;
  line-height: 1;
}

.submit-wrap {
  margin-bottom: 28rpx;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(125deg, #5eead4 0%, #2dd4bf 38%, #14b8a6 72%, #0d9488 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border: none;
  box-shadow: 0 10rpx 28rpx rgba(13, 148, 136, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit:active {
  opacity: 0.9;
}

.btn-submit.loading {
  opacity: 0.72;
}

.btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip-text {
  font-size: 24rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.8;
  padding: 0 20rpx;
}

.text-primary {
  color: #0f766e;
}

.legal-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 8rpx 8rpx 24rpx;
}

.legal-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d1d5db;
  flex-shrink: 0;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  background: #fff;
}

.legal-check.on {
  background: #0f766e;
  border-color: #0f766e;
}

.legal-text {
  flex: 1;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.legal-link {
  display: inline;
  color: #0f766e;
  text-decoration: underline;
}

.forgot-wrap {
  text-align: center;
  padding-top: 24rpx;
}

.forgot-link {
  font-size: 26rpx;
  color: #0f766e;
}

.form-field--row {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
}

.field-grow {
  flex: 1;
  min-width: 0;
}

.sms-btn {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #0f766e;
  font-weight: 600;
  background: rgba(13, 148, 136, 0.1);
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}

.sms-btn.disabled {
  color: #9ca3af;
  background: #f3f4f6;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.picker-cancel {
  font-size: 28rpx;
  color: #9ca3af;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.picker-confirm {
  font-size: 28rpx;
  color: #0f766e;
  font-weight: 600;
}

.picker-list {
  max-height: 600rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx;
  font-size: 30rpx;
  color: #374151;
  border-bottom: 1rpx solid #f9fafb;
}

.picker-item.active {
  color: #0f766e;
  font-weight: 600;
  background: rgba(13, 148, 136, 0.06);
}
