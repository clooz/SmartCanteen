.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #EFF9FF 0%, #F0FDFF 40%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  padding: 0 40rpx 60rpx;
}

/* ===== 品牌区 ===== */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}
.brand-logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(8,145,178,0.2));
}
.brand-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #0891B2;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}
.brand-slogan {
  font-size: 26rpx;
  color: #9CA3AF;
  letter-spacing: 1rpx;
}

/* ===== Tab 切换 ===== */
.tab-bar {
  display: flex;
  background: #E0F7FA;
  border-radius: 48rpx;
  padding: 6rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}
.tab-indicator {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: calc(50% - 6rpx);
  bottom: 6rpx;
  background: #0891B2;
  border-radius: 40rpx;
  transition: transform 0.25s ease;
  z-index: 0;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #9CA3AF;
  position: relative;
  z-index: 1;
  transition: color 0.25s;
}
.tab-item.active { color: #FFFFFF; }

/* ===== 表单卡片 ===== */
.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(8,145,178,0.08);
  overflow: hidden;
  margin-bottom: 32rpx;
}
.form-field {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx;
  min-height: 100rpx;
}
.form-divider {
  height: 1rpx;
  background: #CFFAFE;
  margin: 0 32rpx;
}
.field-label {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  width: 140rpx;
  flex-shrink: 0;
}
.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #164E63;
  border: none;
  outline: none;
  background: transparent;
}
.field-placeholder { color: #D1D5DB; }
.field-value {
  flex: 1;
  font-size: 28rpx;
  color: #164E63;
}
.field-value.placeholder { color: #D1D5DB; }
.field-arrow {
  font-size: 40rpx;
  color: #D1D5DB;
  margin-left: 8rpx;
  line-height: 1;
}

/* ===== 提交按钮 ===== */
.submit-wrap { margin-bottom: 32rpx; }
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #0891B2, #0369A1);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(8,145,178,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-submit:active { opacity: 0.88; }
.btn-submit.loading { opacity: 0.7; }
.btn-loading { display: flex; align-items: center; justify-content: center; }

/* ===== 提示文字 ===== */
.tip-text {
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
  line-height: 1.8;
  padding: 0 20rpx;
}
.text-primary { color: #0891B2; }

/* ===== 公司选择弹窗 ===== */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #CFFAFE;
}
.picker-cancel { font-size: 28rpx; color: #9CA3AF; }
.picker-title { font-size: 32rpx; font-weight: 600; color: #164E63; }
.picker-confirm { font-size: 28rpx; color: #0891B2; font-weight: 600; }
.picker-list { max-height: 600rpx; }
.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx;
  font-size: 30rpx;
  color: #374151;
  border-bottom: 1rpx solid #F0FDFF;
}
.picker-item.active {
  color: #0891B2;
  font-weight: 600;
  background: #E0F7FA;
}
