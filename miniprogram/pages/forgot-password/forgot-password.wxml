<view class="page">
  <view class="hint">通过手机或邮箱验证后设置新密码</view>

  <view class="tab-bar">
    <view class="tab-item {{mode === 'sms' ? 'active' : ''}}" bindtap="switchMode" data-mode="sms">手机找回</view>
    <view class="tab-item {{mode === 'email' ? 'active' : ''}}" bindtap="switchMode" data-mode="email">邮箱找回</view>
    <view class="tab-indicator" style="transform: translateX({{mode === 'sms' ? '0' : '100%'}})"></view>
  </view>

  <view class="form-card">
    <block wx:if="{{mode === 'sms'}}">
      <view class="field">
        <text class="label">手机号</text>
        <input class="input" type="number" maxlength="11" placeholder="已绑定的手机号"
          value="{{phone}}" bindinput="onInput" data-key="phone" />
      </view>
    </block>
    <block wx:else>
      <view class="field">
        <text class="label">邮箱</text>
        <input class="input" placeholder="与登录时使用的邮箱一致"
          value="{{email}}" bindinput="onInput" data-key="email" />
      </view>
    </block>
    <view class="field row">
      <view class="grow">
        <text class="label">验证码</text>
        <input class="input" type="number" maxlength="6" placeholder="6 位验证码"
          value="{{code}}" bindinput="onInput" data-key="code" />
      </view>
      <view class="code-btn {{countdown > 0 || loading ? 'disabled' : ''}}" bindtap="sendCode">
        {{countdown > 0 ? countdown + 's' : '获取验证码'}}
      </view>
    </view>
    <view class="field">
      <text class="label">新密码</text>
      <input class="input" password placeholder="至少 6 位"
        value="{{newPassword}}" bindinput="onInput" data-key="newPassword" />
    </view>
  </view>

  <view wx:if="{{showLegalRow}}" class="legal-row" bindtap="toggleAgree">
    <view class="legal-check {{agreed ? 'on' : ''}}"><text wx:if="{{agreed}}">✓</text></view>
    <view class="legal-text">
      我已阅读并同意
      <navigator class="link" url="/pages/legal/user-agreement/user-agreement">《用户协议》</navigator>
      与
      <navigator class="link" url="/pages/legal/privacy-policy/privacy-policy">《隐私政策》</navigator>
    </view>
  </view>

  <view class="submit-wrap">
    <button class="btn" bindtap="onSubmit" disabled="{{loading}}">
      <van-loading wx:if="{{loading}}" size="32rpx" color="#fff" />
      <text wx:else>重置密码</text>
    </button>
  </view>
</view>
