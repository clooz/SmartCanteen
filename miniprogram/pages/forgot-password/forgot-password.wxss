.page {
  min-height: 100vh;
  background: #f0f4f8;
  padding: 32rpx 40rpx 80rpx;
}

.hint {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.tab-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 48rpx;
  padding: 5rpx;
  margin-bottom: 28rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.tab-indicator {
  position: absolute;
  top: 5rpx;
  left: 5rpx;
  width: calc(50% - 5rpx);
  bottom: 5rpx;
  background: linear-gradient(125deg, #2dd4bf, #0d9488);
  border-radius: 40rpx;
  transition: transform 0.25s ease;
  z-index: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #9ca3af;
  position: relative;
  z-index: 1;
}

.tab-item.active {
  color: #fff;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx 28rpx 28rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.field {
  padding-top: 24rpx;
}

.field.row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.grow {
  flex: 1;
  min-width: 0;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.input {
  font-size: 30rpx;
  color: #111827;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.code-btn {
  flex-shrink: 0;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #0f766e;
  font-weight: 600;
  background: rgba(13, 148, 136, 0.1);
  border-radius: 12rpx;
  margin-bottom: 6rpx;
}

.code-btn.disabled {
  color: #9ca3af;
  background: #f3f4f6;
}

.legal-row {
  display: flex;
  gap: 16rpx;
  padding: 28rpx 8rpx 0;
  align-items: flex-start;
}

.legal-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d1d5db;
  flex-shrink: 0;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  background: #fff;
}

.legal-check.on {
  background: #0f766e;
  border-color: #0f766e;
}

.legal-text {
  flex: 1;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

.link {
  display: inline;
  color: #0f766e;
  text-decoration: underline;
}

.submit-wrap {
  margin-top: 40rpx;
}

.btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(125deg, #14b8a6, #0d9488);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.btn::after {
  border: none;
}
