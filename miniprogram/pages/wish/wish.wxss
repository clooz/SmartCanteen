.page {
  height: 100vh;
  box-sizing: border-box;
  background: #ECFEFF;
  display: flex;
  flex-direction: column;
}

/* ========= 顶区：沉浸渐变 + 搜索 + 筛选 ========= */
.hero {
  flex-shrink: 0;
  background: linear-gradient(155deg, #0e7490 0%, #0369a1 50%, #075985 100%);
  padding-bottom: 16rpx;
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(3, 105, 161, 0.18);
}

.hero-inner {
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.hero-head {
  padding-top: 6rpx;
  padding-bottom: 0;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
  line-height: 1.15;
}

.toolbar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
  min-width: 0;
}

.search-box {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  min-height: 64rpx;
  padding: 0 20rpx 0 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.filter-trigger {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  min-height: 64rpx;
  padding: 0 18rpx 0 20rpx;
  max-width: 200rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.filter-trigger:active {
  opacity: 0.88;
}

.filter-trigger-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #164e63;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-ico {
  flex-shrink: 0;
  margin-right: 8rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  font-size: 26rpx;
  color: #164e63;
}

.search-ph {
  color: #94a3b8;
}

.search-clear {
  flex-shrink: 0;
  padding: 8rpx 4rpx 8rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-clear:active {
  opacity: 0.65;
}

/* ========= 列表主体 ========= */
.body {
  flex: 1;
  min-height: 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  position: relative;
}

.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #64748b;
}

.activity-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.activity-card {
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(8, 145, 178, 0.07);
  border: 1rpx solid rgba(207, 250, 254, 0.9);
}

.activity-card:active {
  transform: scale(0.992);
  box-shadow: 0 8rpx 28rpx rgba(8, 145, 178, 0.12);
}

.activity-card.closed {
  opacity: 0.72;
}

.card-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
  gap: 16rpx;
  min-width: 0;
}

.card-status-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
}

.card-status-badge.active {
  background: #ecfdf5;
  color: #15803d;
}

.card-status-badge.closed {
  background: #f3f4f6;
  color: #9ca3af;
}

.card-countdown {
  font-size: 22rpx;
  color: #b45309;
  background: #fef3c7;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 600;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #164e63;
  margin-bottom: 12rpx;
  line-height: 1.4;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.card-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-pub {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.card-pub-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-width: 0;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.meta-text {
  font-size: 24rpx;
  color: #9ca3af;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-arrow {
  flex-shrink: 0;
  font-size: 44rpx;
  color: #cffafe;
  line-height: 1;
  font-weight: 300;
}

.list-end {
  text-align: center;
  font-size: 24rpx;
  color: #cbd5e1;
  padding: 16rpx 0 32rpx;
}

.empty-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx 120rpx;
  box-sizing: border-box;
}

.empty-area--soft {
  padding-top: 100rpx;
}

.empty-icon {
  font-size: 88rpx;
  margin-bottom: 28rpx;
  opacity: 0.55;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #334155;
  margin-bottom: 16rpx;
  text-align: center;
}

.empty-sub {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  line-height: 1.75;
  max-width: 560rpx;
}
