.page {
  height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(165deg, #eef1f6 0%, #f0f4f8 50%, #eef6f7 100%);
  display: flex;
  flex-direction: column;
}

.hero {
  flex-shrink: 0;
  background: linear-gradient(155deg, #5eead4 0%, #2dd4bf 32%, #14b8a6 62%, #0d9488 100%);
  padding-bottom: 18rpx;
  border-radius: 0 0 22rpx 22rpx;
  box-shadow: 0 8rpx 28rpx rgba(13, 148, 136, 0.18);
}

.hero-inner {
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.hero-head {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  padding-top: 0;
  padding-bottom: 4rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.5rpx;
  line-height: 1.15;
}

.toolbar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
  min-width: 0;
}

.search-box {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  min-height: 64rpx;
  padding: 0 20rpx 0 18rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.filter-trigger {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  min-height: 64rpx;
  padding: 0 18rpx 0 20rpx;
  max-width: 200rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.filter-trigger:active {
  opacity: 0.9;
}

.filter-trigger-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-ico {
  flex-shrink: 0;
  margin-right: 8rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  font-size: 26rpx;
  color: #111827;
}

.search-ph {
  color: #9ca3af;
}

.search-clear {
  flex-shrink: 0;
  padding: 8rpx 4rpx 8rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-clear:active {
  opacity: 0.65;
}

.body {
  flex: 1;
  min-height: 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  position: relative;
}

.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #6b7280;
}

.activity-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.activity-card {
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(15, 23, 42, 0.04);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.activity-card:active {
  transform: scale(0.992);
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.06);
}

.activity-card.closed {
  opacity: 0.72;
}

.card-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
  gap: 14rpx;
  min-width: 0;
}

.card-status-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
}

.card-status-badge.active {
  background: #ecfdf5;
  color: #15803d;
}

.card-status-badge.closed {
  background: #f3f4f6;
  color: #9ca3af;
}

.card-countdown {
  font-size: 22rpx;
  color: #b45309;
  background: #fef3c7;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 600;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 10rpx;
  line-height: 1.4;
  word-break: break-word;
  overflow-wrap: anywhere;
}

.card-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 14rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-pub {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 18rpx;
}

.card-pub-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-width: 0;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.meta-text {
  font-size: 24rpx;
  color: #9ca3af;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: #d1d5db;
  line-height: 1;
  font-weight: 300;
}

.list-end {
  text-align: center;
  font-size: 24rpx;
  color: #d1d5db;
  padding: 16rpx 0 32rpx;
}

.empty-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx 120rpx;
  box-sizing: border-box;
}

.empty-area--soft {
  padding-top: 100rpx;
}

.empty-icon {
  font-size: 88rpx;
  margin-bottom: 28rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 16rpx;
  text-align: center;
}

.empty-sub {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.75;
  max-width: 560rpx;
}
