.page {
  min-height: 100vh;
  background: #F0FDFF;
  display: flex;
  flex-direction: column;
}

.header {
  background: linear-gradient(135deg, #0891B2, #0369A1);
  padding: 48rpx 40rpx 56rpx;
}
.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.header-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 32rpx; opacity: 0.5; }
.empty-title { font-size: 36rpx; font-weight: 700; color: #374151; margin-bottom: 16rpx; }
.empty-sub { font-size: 26rpx; color: #9CA3AF; text-align: center; line-height: 1.8; }

.activity-scroll { flex: 1; padding: 24rpx 32rpx; }

.activity-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(8,145,178,0.08);
  border: 2rpx solid #CFFAFE;
  transition: box-shadow 0.2s;
}
.activity-card:active { box-shadow: 0 4rpx 20rpx rgba(8,145,178,0.14); background: #F0FDFF; }
.activity-card.closed { opacity: 0.65; }

.card-top {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
}
.card-status-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
}
.card-status-badge.active { background: #DCFCE7; color: #16A34A; }
.card-status-badge.closed { background: #F3F4F6; color: #9CA3AF; }

.card-countdown {
  font-size: 22rpx;
  color: #D97706;
  background: #FEF3C7;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 12rpx;
  line-height: 1.4;
}
.card-desc {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  margin-bottom: 24rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}
.meta-text { font-size: 24rpx; color: #9CA3AF; }
.card-arrow { font-size: 44rpx; color: #CFFAFE; line-height: 1; }

.list-end {
  text-align: center;
  font-size: 24rpx;
  color: #D1D5DB;
  padding: 20rpx 0 40rpx;
}
