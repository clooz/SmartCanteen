<view class="page">
  <!-- 自定义顶区：安全区 + 标题 + 搜索 + 筛选 -->
  <view class="hero" style="padding-top: {{statusBarHeight}}px;">
    <view class="hero-inner">
      <view class="hero-head">
        <text class="hero-title">许愿活动</text>
      </view>

      <view class="toolbar-row">
        <view class="search-box">
          <van-icon class="search-ico" name="search" size="30rpx" color="rgba(22,78,99,0.45)" />
          <input
            class="search-input"
            type="text"
            placeholder="搜标题或说明"
            placeholder-class="search-ph"
            value="{{searchKeyword}}"
            bindinput="onSearchInput"
            confirm-type="search"
          />
          <view wx:if="{{searchKeyword}}" class="search-clear" catchtap="clearSearch">
            <van-icon name="cross" size="28rpx" color="#94A3B8" />
          </view>
        </view>
        <picker mode="selector" range="{{statusFilterRange}}" range-key="label" value="{{filterIndex}}" bindchange="onFilterPick">
          <view class="filter-trigger">
            <text class="filter-trigger-text">{{statusFilterRange[filterIndex].label}}</text>
            <van-icon name="arrow-down" size="24rpx" color="rgba(22,78,99,0.5)" />
          </view>
        </picker>
      </view>
    </view>
  </view>

  <view class="body">
    <view wx:if="{{loading}}" class="loading-wrap">
      <van-loading type="spinner" color="#0891B2" size="48rpx" />
      <text class="loading-text">加载中</text>
    </view>

    <scroll-view wx:elif="{{activities.length > 0}}" scroll-y class="activity-scroll" enhanced show-scrollbar="{{false}}" enable-passive>
      <view
        wx:for="{{activities}}"
        wx:key="id"
        class="activity-card {{item.status === 'closed' ? 'closed' : ''}}"
        bindtap="goDetail"
        data-id="{{item.id}}"
        data-title="{{item.title}}"
      >
        <view class="card-top">
          <view class="card-status-badge {{item.status === 'active' ? 'active' : 'closed'}}">
            {{item.status === 'active' ? '进行中' : '已结束'}}
          </view>
          <view wx:if="{{item.status === 'active'}}" class="card-countdown">{{item.countdown}}</view>
        </view>

        <view class="card-title">{{item.title}}</view>
        <view wx:if="{{item.description}}" class="card-desc">{{item.description}}</view>
        <view class="card-pub">
          <van-icon name="notes" size="22rpx" color="#9CA3AF" />
          <text class="card-pub-text">发布于 {{item.createdAtStr}}</text>
        </view>

        <view class="card-footer">
          <view class="card-meta">
            <van-icon name="friends-o" size="28rpx" color="#9CA3AF" />
            <text class="meta-text">{{item.item_count || 0}} 个愿望</text>
          </view>
          <view class="card-meta">
            <van-icon name="clock-o" size="28rpx" color="#9CA3AF" />
            <text class="meta-text">截止 {{item.endAtStr}}</text>
          </view>
          <view class="card-arrow">›</view>
        </view>
      </view>

      <view class="list-end">共 {{activities.length}} 条活动</view>
    </scroll-view>

    <view wx:elif="{{emptyMode === 'nomatch'}}" class="empty-area empty-area--soft">
      <view class="empty-icon">🔍</view>
      <view class="empty-title">未找到相关活动</view>
      <view class="empty-sub">试试更短的关键词，或将状态改为「全部」再试</view>
    </view>

    <view wx:else class="empty-area">
      <view class="empty-icon">🌟</view>
      <view class="empty-title">
        <block wx:if="{{filterTab === 'active'}}">暂无进行中的活动</block>
        <block wx:elif="{{filterTab === 'closed'}}">暂无已结束的活动</block>
        <block wx:else>暂无许愿活动</block>
      </view>
      <view class="empty-sub">
        <block wx:if="{{filterTab === 'active'}}">发起方开启活动后会出现在这里；也可切到「全部」查看历史。</block>
        <block wx:elif="{{filterTab === 'closed'}}">结束后归档的活动将显示在此。</block>
        <block wx:else>等待食堂发起活动，快来许愿吧～</block>
      </view>
    </view>
  </view>
</view>
