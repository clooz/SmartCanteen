<view class="page">
  <view class="filter-bar" bindtap="openFilterSheet">
    <view class="filter-bar-left">
      <van-icon name="filter-o" size="34rpx" color="#0F766E" />
      <text class="filter-bar-label">筛选</text>
      <text class="filter-bar-sum">{{filterSummaryText}}</text>
    </view>
    <van-icon name="arrow-down" size="28rpx" color="#94A3B8" />
  </view>

  <view wx:if="{{loading && records.length === 0}}" class="loading-wrap">
    <van-loading type="spinner" color="#14B8A6" size="48rpx" />
  </view>

  <view wx:elif="{{records.length === 0}}" class="empty-area">
    <view class="empty-icon">💳</view>
    <view class="empty-title">暂无符合条件的记录</view>
    <view class="empty-sub">点上方「筛选」调整条件，或去「充值」页提交申请</view>
  </view>

  <scroll-view wx:else scroll-y class="record-scroll" enhanced show-scrollbar="{{false}}" enable-passive bindscrolltolower="onLoadMore">
    <view wx:for="{{records}}" wx:key="id" class="record-card">
      <view class="record-top">
        <view class="record-amount">+¥{{item.amount}}</view>
        <view class="record-status {{item.status}}">
          <text wx:if="{{item.status === 'pending'}}">⏳ 待审核</text>
          <text wx:elif="{{item.status === 'completed'}}">✅ 已到账</text>
          <text wx:else>❌ 已拒绝</text>
        </view>
      </view>

      <view class="record-time">申请时间：{{item.createdAtStr}}</view>

      <view wx:if="{{item.remark}}" class="record-remark">备注：{{item.remark}}</view>

      <view wx:if="{{item.status === 'rejected' && item.review_note}}" class="review-note">
        <van-icon name="warning-o" size="28rpx" color="#DC2626" />
        <text>{{item.review_note}}</text>
      </view>

      <view wx:if="{{item.status === 'completed' && item.reviewed_at}}" class="record-reviewed">
        审核通过：{{item.reviewedAtStr}}
      </view>

      <view wx:if="{{item.proof_image_url}}" class="proof-thumb-wrap" bindtap="previewProof" data-url="{{item.proof_image_url}}">
        <image class="proof-thumb" src="{{item.proof_image_url}}" mode="aspectFill" />
        <text class="proof-label">查看凭证</text>
      </view>
    </view>

    <view class="list-end">
      <van-loading wx:if="{{loadingMore}}" type="spinner" size="32rpx" color="#14B8A6" />
      <text wx:elif="{{noMore}}">已显示全部记录</text>
    </view>
  </scroll-view>

  <van-popup
    show="{{showFilterSheet}}"
    position="bottom"
    round
    bind:close="closeFilterSheet"
    custom-style="max-height: 70vh;"
  >
    <view class="sheet">
      <view class="sheet-head">
        <text class="sheet-title">筛选</text>
        <view class="sheet-head-actions">
          <text class="sheet-link" bindtap="resetDraftFilter">重置</text>
          <text class="sheet-done" bindtap="applyFilterFromSheet">完成</text>
        </view>
      </view>

      <view class="sheet-section">
        <text class="sheet-sec-title">状态</text>
        <view
          wx:for="{{statusChips}}"
          wx:key="label"
          class="sheet-row {{draftStatus === item.value ? 'sheet-row--on' : ''}}"
          data-value="{{item.value}}"
          bindtap="onDraftStatus"
        >
          <text>{{item.label}}</text>
          <van-icon wx:if="{{draftStatus === item.value}}" name="success" size="36rpx" color="#0F766E" />
        </view>
      </view>

      <view class="sheet-section">
        <text class="sheet-sec-title">时间</text>
        <view
          wx:for="{{rangeChips}}"
          wx:key="label"
          class="sheet-row {{draftRange === item.value ? 'sheet-row--on' : ''}}"
          data-value="{{item.value}}"
          bindtap="onDraftRange"
        >
          <text>{{item.label}}</text>
          <van-icon wx:if="{{draftRange === item.value}}" name="success" size="36rpx" color="#0F766E" />
        </view>
      </view>
    </view>
  </van-popup>
</view>
