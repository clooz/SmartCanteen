<view class="page">
  <view wx:if="{{loading && records.length === 0}}" class="loading-wrap">
    <van-loading type="spinner" color="#DC2626" size="48rpx" />
  </view>

  <view wx:elif="{{records.length === 0}}" class="empty-area">
    <view class="empty-icon">💳</view>
    <view class="empty-title">暂无充值记录</view>
    <view class="empty-sub">去「充值」页提交申请吧</view>
  </view>

  <scroll-view wx:else scroll-y class="record-scroll" enable-passive bindscrolltolower="onLoadMore">
    <view wx:for="{{records}}" wx:key="id" class="record-card">
      <view class="record-top">
        <view class="record-amount">+¥{{item.amount}}</view>
        <view class="record-status {{item.status}}">
          <text wx:if="{{item.status === 'pending'}}">⏳ 审核中</text>
          <text wx:elif="{{item.status === 'completed'}}">✅ 已到账</text>
          <text wx:else>❌ 已拒绝</text>
        </view>
      </view>

      <view class="record-time">申请时间：{{item.createdAtStr}}</view>

      <view wx:if="{{item.remark}}" class="record-remark">备注：{{item.remark}}</view>

      <view wx:if="{{item.status === 'rejected' && item.review_note}}" class="review-note">
        <van-icon name="warning-o" size="28rpx" color="#DC2626" />
        <text>{{item.review_note}}</text>
      </view>

      <view wx:if="{{item.status === 'completed' && item.reviewed_at}}" class="record-reviewed">
        审核通过：{{item.reviewedAtStr}}
      </view>

      <!-- 凭证图预览 -->
      <view wx:if="{{item.proof_image_url}}" class="proof-thumb-wrap" bindtap="previewProof" data-url="{{item.proof_image_url}}">
        <image class="proof-thumb" src="{{item.proof_image_url}}" mode="aspectFill" />
        <text class="proof-label">查看凭证</text>
      </view>
    </view>

    <view class="list-end">
      <van-loading wx:if="{{loadingMore}}" type="spinner" size="32rpx" color="#DC2626" />
      <text wx:elif="{{noMore}}">已显示全部记录</text>
    </view>
  </scroll-view>
</view>
