.page {
  min-height: 100vh;
  background: #F0FDFF;
  padding-bottom: 40rpx;
}

.loading-wrap { display: flex; justify-content: center; padding: 120rpx 0; }

.empty-area {
  display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 28rpx; opacity: 0.5; }
.empty-title { font-size: 34rpx; font-weight: 700; color: #374151; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: #9CA3AF; }

.record-scroll { height: 100vh; padding: 24rpx 32rpx; box-sizing: border-box; }

.record-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(8,145,178,0.06);
}

.record-top {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx;
}
.record-amount { font-size: 44rpx; font-weight: 700; color: #0891B2; }

.record-status {
  font-size: 24rpx; font-weight: 600; padding: 8rpx 20rpx; border-radius: 24rpx;
}
.record-status.pending   { background: #FEF9C3; color: #D97706; }
.record-status.completed { background: #DCFCE7; color: #16A34A; }
.record-status.rejected  { background: #FEE2E2; color: #DC2626; }

.record-time { font-size: 24rpx; color: #9CA3AF; margin-bottom: 8rpx; }
.record-remark { font-size: 26rpx; color: #6B7280; margin-bottom: 8rpx; }

.review-note {
  display: flex; align-items: flex-start; gap: 8rpx;
  background: #FEF2F2; border-radius: 12rpx; padding: 16rpx 20rpx;
  font-size: 26rpx; color: #DC2626; margin-top: 12rpx;
}
.record-reviewed { font-size: 24rpx; color: #16A34A; margin-top: 8rpx; }

.proof-thumb-wrap {
  display: flex; align-items: center; gap: 16rpx;
  margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #CFFAFE;
}
.proof-thumb {
  width: 80rpx; height: 80rpx; border-radius: 12rpx; background: #F3F4F6;
}
.proof-label { font-size: 26rpx; color: #0891B2; }

.list-end {
  text-align: center; padding: 32rpx 0 20rpx;
  font-size: 24rpx; color: #D1D5DB;
  display: flex; align-items: center; justify-content: center;
}
