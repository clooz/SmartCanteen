.page {
  min-height: 100vh;
  height: 100vh;
  background: linear-gradient(165deg, #eef1f6 0%, #f0f4f8 45%, #eef6f7 100%);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.filter-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 22rpx;
  margin: 10rpx 28rpx 6rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.filter-bar:active {
  opacity: 0.92;
}

.filter-bar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
}

.filter-bar-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  flex-shrink: 0;
}

.filter-bar-sum {
  font-size: 24rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
  flex: 1;
  min-height: 0;
}

.empty-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  flex: 1;
  min-height: 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 28rpx;
  opacity: 0.45;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.5;
}

.record-scroll {
  flex: 1;
  min-height: 0;
  padding: 12rpx 28rpx 22rpx;
  box-sizing: border-box;
}

.record-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 18rpx;
  padding: 28rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.035);
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.record-amount {
  font-size: 42rpx;
  font-weight: 700;
  color: #0f766e;
}

.record-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
}

.record-status.pending {
  background: #fef9c3;
  color: #d97706;
}

.record-status.completed {
  background: #dcfce7;
  color: #16a34a;
}

.record-status.rejected {
  background: #fee2e2;
  color: #dc2626;
}

.record-time {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
}

.record-remark {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.review-note {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  background: #fef2f2;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  font-size: 26rpx;
  color: #dc2626;
  margin-top: 10rpx;
}

.record-reviewed {
  font-size: 24rpx;
  color: #16a34a;
  margin-top: 8rpx;
}

.proof-thumb-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f3f4f6;
}

.proof-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

.proof-label {
  font-size: 26rpx;
  color: #0f766e;
}

.list-end {
  text-align: center;
  padding: 28rpx 0 18rpx;
  font-size: 24rpx;
  color: #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sheet {
  padding: 8rpx 0 calc(24rpx + env(safe-area-inset-bottom));
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.sheet-head-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.sheet-link {
  font-size: 28rpx;
  color: #6b7280;
}

.sheet-done {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f766e;
}

.sheet-section {
  padding: 8rpx 0 16rpx;
}

.sheet-sec-title {
  display: block;
  padding: 16rpx 32rpx 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
  letter-spacing: 2rpx;
}

.sheet-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #374151;
  border-bottom: 1rpx solid #f9fafb;
}

.sheet-row--on {
  color: #0f766e;
  font-weight: 600;
}

.sheet-row:active {
  background: #f9fafb;
}
