/**
 * 今日菜单 · 现代极简 + 高级渐变
 * 主色：青绿 teal（单色系）｜中性：冷灰 slate
 * 餐次仅作弱区分，避免「彩虹小程序」观感
 */

.page {
  position: relative;
  min-height: 100vh;
  /* 纸面感：极浅冷灰 → 透青，耐看 */
  background: linear-gradient(
    165deg,
    #eef1f6 0%,
    #f0f4f8 24%,
    #eef6f7 52%,
    #e8f2f4 100%
  );
  display: flex;
  flex-direction: column;
  padding-top: 6rpx;
  box-sizing: border-box;
}

.page-atmos {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  height: 56vh;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.page-atmos-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(96rpx);
  opacity: 0.42;
}

/* 光晕：低饱和青绿，不做高亮荧光 */
.page-atmos-blob--a {
  width: 420rpx;
  height: 420rpx;
  background: radial-gradient(circle, rgba(45, 212, 191, 0.35) 0%, rgba(45, 212, 191, 0) 70%);
  top: -120rpx;
  right: -140rpx;
}

.page-atmos-blob--b {
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(13, 148, 136, 0.22) 0%, rgba(13, 148, 136, 0) 72%);
  top: 80rpx;
  left: -100rpx;
}

.menu-top-area,
.menu-scroll,
.loading-wrap,
.empty-area {
  position: relative;
  z-index: 1;
}

/* ========== 顶部信息 ========== */
.menu-top-area {
  padding: 8rpx 28rpx 0;
  margin-bottom: 4rpx;
}

.menu-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 8rpx 22rpx;
  gap: 24rpx;
}

.menu-hero-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.menu-hero-date-line {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  letter-spacing: 0.5rpx;
  line-height: 1.22;
}

.menu-hero-sub {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
  line-height: 1.45;
}

.menu-hero-stat {
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  box-shadow:
    0 1rpx 0 rgba(255, 255, 255, 0.9) inset,
    0 8rpx 28rpx rgba(15, 23, 42, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.menu-hero-stat-num {
  font-size: 38rpx;
  font-weight: 700;
  color: #0f766e;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.menu-hero-stat-unit {
  font-size: 20rpx;
  color: #9ca3af;
  font-weight: 600;
}

/* ========== 去下单：单色相渐变 + 克制投影 ========== */
.order-cta {
  position: relative;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(13, 148, 136, 0.22);
}

.order-cta:active {
  transform: scale(0.987);
  opacity: 0.97;
}

.order-cta-glow {
  position: absolute;
  inset: 0;
  background: linear-gradient(125deg, #5eead4 0%, #2dd4bf 38%, #14b8a6 72%, #0d9488 100%);
}

.order-cta-inner {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx 26rpx 24rpx;
}

.order-cta-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.order-cta-icon-wrap {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.order-cta-texts {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.order-cta-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.order-cta-sub {
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.88);
  font-weight: 500;
}

.order-cta-arrow {
  font-size: 44rpx;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1;
  padding-bottom: 4rpx;
}

/* ========== 加载 ========== */
.loading-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 48rpx 120rpx;
}

.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 22rpx;
  padding: 44rpx 52rpx;
  background: rgba(255, 255, 255, 0.82);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 32rpx rgba(15, 23, 42, 0.05);
}

.loading-text {
  font-size: 27rpx;
  color: #6b7280;
  font-weight: 500;
}

/* ========== 空状态 ========== */
.empty-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72rpx 48rpx 80rpx;
}

.empty-orbit {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-orbit-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(15, 23, 42, 0.06);
}

.empty-bowl {
  position: relative;
  font-size: 88rpx;
  line-height: 1;
  opacity: 0.88;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
}

.empty-date {
  font-size: 26rpx;
  color: #0f766e;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 40rpx;
  max-width: 540rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #14b8a6, #0d9488);
  color: #fff;
  padding: 20rpx 64rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 10rpx 28rpx rgba(13, 148, 136, 0.28);
}

.empty-btn:active {
  opacity: 0.92;
}

.empty-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
}

.empty-link {
  font-size: 27rpx;
  color: #0f766e;
  font-weight: 600;
  padding: 12rpx 8rpx;
}

.empty-actions-dot {
  color: #d1d5db;
  font-size: 26rpx;
}

/* ========== 滚动区 ========== */
.menu-scroll {
  flex: 1;
  padding: 0 0 48rpx;
  box-sizing: border-box;
}

.meal-block {
  margin: 0 28rpx 32rpx;
}

.meal-block--bf .dish-stack,
.meal-block--lunch .dish-stack {
  padding-top: 2rpx;
}

/* ========== 餐次标题：白底 + 极弱渐变边，餐次用细色条区分 ========== */
.section-cap {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 22rpx;
  margin: 0 0 14rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(255, 255, 255, 0.78) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow: 0 4rpx 24rpx rgba(15, 23, 42, 0.04);
}

.section-cap--bf {
  box-shadow:
    0 0 0 1rpx rgba(180, 165, 120, 0.12) inset,
    0 4rpx 24rpx rgba(15, 23, 42, 0.04);
}

.section-cap--lunch {
  box-shadow:
    0 0 0 1rpx rgba(45, 212, 191, 0.14) inset,
    0 4rpx 24rpx rgba(15, 23, 42, 0.04);
}

.section-cap-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  background: rgba(249, 250, 251, 0.95);
  border: 1rpx solid rgba(15, 23, 42, 0.05);
}

.section-cap-mid {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.section-cap-kicker {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  color: #9ca3af;
  text-transform: uppercase;
}

.section-cap--bf .section-cap-kicker {
  color: #a8a29e;
}

.section-cap--lunch .section-cap-kicker {
  color: #94a3b8;
}

.section-cap-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  letter-spacing: 2rpx;
}

.section-cap-badge {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 600;
  color: #6b7280;
  background: rgba(243, 244, 246, 0.95);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
}

.section-cap-chevron {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin-left: 4rpx;
}

.section-cap--pressed {
  opacity: 0.88;
}

/* ========== 菜品卡片：iOS 分组感 ========== */
.dish-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dish-card {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  padding: 18rpx 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 18rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  box-shadow: 0 2rpx 16rpx rgba(15, 23, 42, 0.035);
  overflow: hidden;
}

.dish-card:active {
  background: rgba(255, 255, 255, 1);
  box-shadow: 0 1rpx 8rpx rgba(15, 23, 42, 0.04);
}

.dish-img-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(145deg, #f3f4f6, #e5e7eb);
  margin-right: 20rpx;
}

.dish-card--bf .dish-img-wrap {
  background: linear-gradient(145deg, #fafaf9, #f5f5f4);
}

.dish-card--lunch .dish-img-wrap {
  background: linear-gradient(145deg, #f0fdfa, #e5f4f1);
}

.dish-img {
  width: 100%;
  height: 100%;
}

.dish-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #f3f4f6, #e7e5e4);
}

.dish-emoji {
  font-size: 56rpx;
  opacity: 0.38;
}

.dish-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  min-height: 160rpx;
  justify-content: center;
}

.dish-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 6rpx;
}

.dish-name {
  flex: 1;
  min-width: 0;
  font-size: 31rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.38;
}

/* 单价：与品牌同一色相，不再早/午两套色 */
.dish-price {
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
  font-variant-numeric: tabular-nums;
  padding-top: 2rpx;
  color: #0f766e;
}

.dish-price--bf,
.dish-price--lunch {
  color: #0f766e;
}

.dish-desc {
  font-size: 24rpx;
  color: #9ca3af;
  line-height: 1.52;
  flex: 1;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.dish-footer {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.dish-category {
  font-size: 21rpx;
  color: #0f766e;
  font-weight: 600;
  background: rgba(13, 148, 136, 0.08);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  border: none;
}

.dish-card--bf .dish-category {
  color: #57534e;
  background: rgba(120, 113, 108, 0.08);
}

/* ========== 列表底部 ========== */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 40rpx 28rpx 28rpx;
}

.list-end-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #d1d5db;
  opacity: 0.7;
}

.list-end-text {
  font-size: 23rpx;
  color: #9ca3af;
  font-weight: 500;
}
