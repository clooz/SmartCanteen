<view class="page">
  <!-- 顶部日期栏 -->
  <view class="header">
    <view class="header-left">
      <view class="header-date">{{todayStr}}</view>
      <view class="header-title">今日菜单</view>
    </view>
    <view class="header-refresh" bindtap="onRefresh">
      <van-icon name="replay" size="40rpx" color="#fff" />
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <van-loading type="spinner" color="#DC2626" size="48rpx" />
    <text style="margin-left:16rpx;color:#DC2626;font-size:26rpx;">加载中...</text>
  </view>

  <!-- 无菜单 -->
  <view wx:elif="{{!hasMenu}}" class="empty-area">
    <view class="empty-bowl">🍜</view>
    <view class="empty-title">今日菜单暂未发布</view>
    <view class="empty-sub">食堂小哥正在努力配菜，请稍后查看～</view>
    <view class="empty-btn" bindtap="onRefresh">刷新试试</view>
  </view>

  <!-- 菜单内容 -->
  <scroll-view wx:elif="{{hasMenu}}" scroll-y class="menu-scroll" enable-passive>
    <!-- 早餐区 -->
    <view wx:if="{{breakfastDishes.length > 0}}" class="meal-section">
      <van-sticky offset-top="0">
        <view class="section-header breakfast">
          <view class="section-icon">☀️</view>
          <view class="section-title">早  餐</view>
          <view class="section-count">{{breakfastDishes.length}} 道</view>
        </view>
      </van-sticky>
      <view class="dish-grid">
        <view
          wx:for="{{breakfastDishes}}"
          wx:key="id"
          class="dish-card"
        >
          <view class="dish-img-wrap">
            <image
              wx:if="{{item.image_url}}"
              class="dish-img"
              src="{{item.image_url}}"
              mode="aspectFill"
              lazy-load
            />
            <view wx:else class="dish-img-placeholder">
              <text class="dish-emoji">🍽</text>
            </view>
          </view>
          <view class="dish-info">
            <view class="dish-name">{{item.name}}</view>
            <view wx:if="{{item.description}}" class="dish-desc">{{item.description}}</view>
            <view class="dish-footer">
              <view class="dish-category">{{item.category || '其他'}}</view>
              <view class="dish-price">¥{{item.price}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 午餐区 -->
    <view wx:if="{{lunchDishes.length > 0}}" class="meal-section">
      <van-sticky offset-top="0">
        <view class="section-header lunch">
          <view class="section-icon">🌤</view>
          <view class="section-title">午  饭</view>
          <view class="section-count">{{lunchDishes.length}} 道</view>
        </view>
      </van-sticky>
      <view class="dish-grid">
        <view
          wx:for="{{lunchDishes}}"
          wx:key="id"
          class="dish-card"
        >
          <view class="dish-img-wrap">
            <image
              wx:if="{{item.image_url}}"
              class="dish-img"
              src="{{item.image_url}}"
              mode="aspectFill"
              lazy-load
            />
            <view wx:else class="dish-img-placeholder">
              <text class="dish-emoji">🍽</text>
            </view>
          </view>
          <view class="dish-info">
            <view class="dish-name">{{item.name}}</view>
            <view wx:if="{{item.description}}" class="dish-desc">{{item.description}}</view>
            <view class="dish-footer">
              <view class="dish-category">{{item.category || '其他'}}</view>
              <view class="dish-price">¥{{item.price}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="list-end">今日菜品已全部展示</view>
  </scroll-view>
</view>
