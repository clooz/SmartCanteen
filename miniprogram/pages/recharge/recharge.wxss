.page {
  height: 100vh;
  box-sizing: border-box;
  background: #ecfeff;
  display: flex;
  flex-direction: column;
}

/* ========= 顶区：与许愿列表 hero 一致 ========= */
.hero {
  flex-shrink: 0;
  background: linear-gradient(155deg, #0e7490 0%, #0369a1 50%, #075985 100%);
  padding-bottom: 20rpx;
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(3, 105, 161, 0.18);
}

.hero-inner {
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.hero-head {
  padding-top: 6rpx;
  padding-bottom: 4rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
  line-height: 1.15;
}

.hero-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.88);
  font-weight: 400;
}

/* ========= 表单主体 ========= */
.body {
  flex: 1;
  min-height: 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.form-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.form-wrap {
  padding: 16rpx 28rpx 24rpx;
}

.form-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(8, 145, 178, 0.07);
  border: 1rpx solid rgba(207, 250, 254, 0.9);
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 20rpx;
}
.required { color: #ef4444; }
.section-hint { font-size: 24rpx; color: #9ca3af; margin-top: -12rpx; margin-bottom: 20rpx; }

/* ===== 金额输入 ===== */
.amount-input-wrap {
  display: flex;
  align-items: center;
  background: #f0fdff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #cffafe;
  margin-bottom: 24rpx;
}
.currency-symbol { font-size: 44rpx; font-weight: 700; color: #0891b2; margin-right: 8rpx; }
.amount-input { flex: 1; font-size: 48rpx; font-weight: 700; color: #164e63; border: none; background: transparent; }
.amount-placeholder { color: #d1d5db; font-size: 32rpx; font-weight: 400; }

.quick-amounts { display: flex; gap: 16rpx; flex-wrap: wrap; }
.quick-btn {
  background: #e0f7fa;
  color: #0891b2;
  font-size: 28rpx;
  font-weight: 500;
  padding: 12rpx 32rpx;
  border-radius: 48rpx;
  border: 2rpx solid #cffafe;
  transition: all 0.15s;
}
.quick-btn:active { opacity: 0.8; }
.quick-btn.active { background: #0891b2; color: #fff; border-color: #0891b2; }

/* ===== 上传区域 ===== */
.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f0fdff;
  border: 2rpx dashed #7dd3fc;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  gap: 12rpx;
}
.upload-area:active { background: #e0f7fa; }
.upload-icon { font-size: 60rpx; }
.upload-text { font-size: 30rpx; font-weight: 600; color: #374151; }
.upload-sub { font-size: 24rpx; color: #9ca3af; }

.image-preview-wrap {
  position: relative;
  display: inline-block;
  width: 100%;
}
.proof-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background: #f9fafb;
}
.image-del {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.image-del:active { background: rgba(0, 0, 0, 0.65); }

/* ===== 备注 ===== */
.remark-input {
  width: 100%;
  min-height: 120rpx;
  background: #f0fdff;
  border: 2rpx solid #cffafe;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #164e63;
  box-sizing: border-box;
}
.remark-placeholder { color: #d1d5db; }

/* ===== 说明卡片 ===== */
.notice-card {
  background: #fffbeb;
  border: 2rpx solid #fde68a;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
}
.notice-title { font-size: 28rpx; font-weight: 600; color: #92400e; margin-bottom: 16rpx; }
.notice-item { font-size: 26rpx; color: #78350f; line-height: 2; }

/* ===== 提交按钮 ===== */
.submit-wrap {
  flex-shrink: 0;
  padding: 8rpx 28rpx 16rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ecfeff;
}
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #0891b2, #0369a1);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(8, 145, 178, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-submit:active { opacity: 0.88; }
.btn-submit.disabled { background: #d1d5db; box-shadow: none; }
