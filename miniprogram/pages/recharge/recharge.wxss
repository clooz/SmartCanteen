.page {
  height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(165deg, #eef1f6 0%, #f0f4f8 50%, #eef6f7 100%);
  display: flex;
  flex-direction: column;
}

.hero {
  flex-shrink: 0;
  background: linear-gradient(155deg, #5eead4 0%, #2dd4bf 32%, #14b8a6 62%, #0d9488 100%);
  padding-bottom: 22rpx;
  border-radius: 0 0 22rpx 22rpx;
  box-shadow: 0 8rpx 28rpx rgba(13, 148, 136, 0.18);
}

.hero-inner {
  padding-left: 28rpx;
  padding-right: 28rpx;
}

.hero-head {
  display: flex;
  flex-direction: column;
  justify-content: center;
  box-sizing: border-box;
  padding-top: 0;
  padding-bottom: 6rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.5rpx;
  line-height: 1.15;
}

.hero-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 400;
}

.body {
  flex: 1;
  min-height: 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.form-scroll {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
}

.form-wrap {
  padding: 14rpx 28rpx 22rpx;
}

.form-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 16rpx rgba(15, 23, 42, 0.04);
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 18rpx;
}

.required {
  color: #ef4444;
}

.section-hint {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: -10rpx;
  margin-bottom: 18rpx;
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  background: #f9fafb;
  border-radius: 14rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #e5e7eb;
  margin-bottom: 22rpx;
}

.currency-symbol {
  font-size: 42rpx;
  font-weight: 700;
  color: #0f766e;
  margin-right: 8rpx;
}

.amount-input {
  flex: 1;
  font-size: 46rpx;
  font-weight: 700;
  color: #111827;
  border: none;
  background: transparent;
}

.amount-placeholder {
  color: #d1d5db;
  font-size: 32rpx;
  font-weight: 400;
}

.quick-amounts {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.quick-btn {
  background: rgba(13, 148, 136, 0.1);
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 500;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(13, 148, 136, 0.2);
}

.quick-btn:active {
  opacity: 0.85;
}

.quick-btn.active {
  background: linear-gradient(125deg, #2dd4bf, #14b8a6, #0d9488);
  color: #fff;
  border-color: transparent;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f9fafb;
  border: 2rpx dashed #d1d5db;
  border-radius: 14rpx;
  padding: 56rpx 36rpx;
  gap: 10rpx;
}

.upload-area:active {
  background: #f3f4f6;
}

.upload-icon {
  font-size: 56rpx;
}

.upload-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
}

.upload-sub {
  font-size: 24rpx;
  color: #9ca3af;
}

.image-preview-wrap {
  position: relative;
  display: inline-block;
  width: 100%;
}

.proof-image {
  width: 100%;
  height: 400rpx;
  border-radius: 14rpx;
  background: #f9fafb;
}

.image-del {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-del:active {
  background: rgba(0, 0, 0, 0.65);
}

.remark-input {
  width: 100%;
  min-height: 120rpx;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 18rpx;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
}

.remark-placeholder {
  color: #d1d5db;
}

.notice-card {
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  border-radius: 14rpx;
  padding: 26rpx 28rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400e;
  margin-bottom: 14rpx;
}

.notice-item {
  font-size: 26rpx;
  color: #78350f;
  line-height: 2;
}

.submit-wrap {
  flex-shrink: 0;
  padding: 8rpx 28rpx 14rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  background: transparent;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(125deg, #5eead4 0%, #2dd4bf 38%, #14b8a6 72%, #0d9488 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border: none;
  box-shadow: 0 10rpx 28rpx rgba(13, 148, 136, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit:active {
  opacity: 0.9;
}

.btn-submit.disabled {
  background: #9ca3af;
  box-shadow: none;
}
