.page {
  min-height: 100vh;
  background: #F0FDFF;
  display: flex;
  flex-direction: column;
  padding-bottom: 60rpx;
}

.header {
  background: linear-gradient(135deg, #0891B2, #0369A1);
  padding: 48rpx 40rpx 56rpx;
}
.header-title { font-size: 44rpx; font-weight: 700; color: #fff; letter-spacing: 4rpx; margin-bottom: 8rpx; }
.header-sub { font-size: 24rpx; color: rgba(255,255,255,0.75); }

.form-wrap { padding: 32rpx; flex: 1; }

.form-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(8,145,178,0.06);
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 20rpx;
}
.required { color: #EF4444; }
.section-hint { font-size: 24rpx; color: #9CA3AF; margin-top: -12rpx; margin-bottom: 20rpx; }

/* ===== 金额输入 ===== */
.amount-input-wrap {
  display: flex;
  align-items: center;
  background: #F0FDFF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #CFFAFE;
  margin-bottom: 24rpx;
}
.currency-symbol { font-size: 44rpx; font-weight: 700; color: #0891B2; margin-right: 8rpx; }
.amount-input { flex: 1; font-size: 48rpx; font-weight: 700; color: #164E63; border: none; background: transparent; }
.amount-placeholder { color: #D1D5DB; font-size: 32rpx; font-weight: 400; }

.quick-amounts { display: flex; gap: 16rpx; flex-wrap: wrap; }
.quick-btn {
  background: #E0F7FA;
  color: #0891B2;
  font-size: 28rpx;
  font-weight: 500;
  padding: 12rpx 32rpx;
  border-radius: 48rpx;
  border: 2rpx solid #CFFAFE;
  transition: all 0.15s;
}
.quick-btn:active { opacity: 0.8; }
.quick-btn.active { background: #0891B2; color: #fff; border-color: #0891B2; }

/* ===== 上传区域 ===== */
.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #F0FDFF;
  border: 2rpx dashed #7DD3FC;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  gap: 12rpx;
}
.upload-area:active { background: #E0F7FA; }
.upload-icon { font-size: 60rpx; }
.upload-text { font-size: 30rpx; font-weight: 600; color: #374151; }
.upload-sub { font-size: 24rpx; color: #9CA3AF; }

.image-preview-wrap {
  position: relative;
  display: inline-block;
  width: 100%;
}
.proof-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background: #F9FAFB;
}
.image-del {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0,0,0,0.45);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.image-del:active { background: rgba(0,0,0,0.65); }

/* ===== 备注 ===== */
.remark-input {
  width: 100%;
  min-height: 120rpx;
  background: #F0FDFF;
  border: 2rpx solid #CFFAFE;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #164E63;
  box-sizing: border-box;
}
.remark-placeholder { color: #D1D5DB; }

/* ===== 说明卡片 ===== */
.notice-card {
  background: #FFFBEB;
  border: 2rpx solid #FDE68A;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
}
.notice-title { font-size: 28rpx; font-weight: 600; color: #92400E; margin-bottom: 16rpx; }
.notice-item { font-size: 26rpx; color: #78350F; line-height: 2; }

/* ===== 提交按钮 ===== */
.submit-wrap { padding: 8rpx 32rpx 32rpx; }
.btn-submit {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #0891B2, #0369A1);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(8,145,178,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-submit:active { opacity: 0.88; }
.btn-submit.disabled { background: #D1D5DB; box-shadow: none; }
