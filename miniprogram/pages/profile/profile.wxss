.page {
  min-height: 100vh;
  background: linear-gradient(165deg, #eef1f6 0%, #f0f4f8 45%, #eef6f7 100%);
  padding-bottom: 60rpx;
}

.user-card {
  background: linear-gradient(125deg, #5eead4 0%, #2dd4bf 35%, #14b8a6 70%, #0d9488 100%);
  padding: 56rpx 36rpx 44rpx;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.avatar-wrap:active {
  opacity: 0.88;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.35);
  overflow: hidden;
}

.user-avatar--img {
  display: block;
  width: 100rpx;
  height: 100rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.user-company {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.user-dot {
  color: rgba(255, 255, 255, 0.45);
}

.user-role {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.95);
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 14rpx;
  border-radius: 24rpx;
}

.user-sub {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
}

.user-sub--warn {
  color: rgba(254, 243, 199, 0.95);
}

.user-edit {
  padding: 8rpx;
}

.user-edit:active {
  opacity: 0.7;
}

.menu-group {
  padding: 24rpx 28rpx 0;
}

.group-title {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 10rpx;
  padding-left: 4rpx;
}

.menu-card {
  background: #ffffff;
  border-radius: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 26rpx;
  min-height: 100rpx;
}

.menu-item:active {
  background: #f9fafb;
}

.menu-item.disabled {
  opacity: 0.5;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 22rpx;
  flex-shrink: 0;
}

.menu-icon.recharge {
  background: rgba(234, 179, 8, 0.12);
}

.menu-icon.order {
  background: rgba(13, 148, 136, 0.12);
}

.menu-icon.nickname {
  background: rgba(59, 130, 246, 0.1);
}

.menu-icon.password {
  background: rgba(34, 197, 94, 0.1);
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
}

.menu-arrow {
  font-size: 40rpx;
  color: #d1d5db;
  line-height: 1;
}

.menu-badge {
  font-size: 22rpx;
  color: #b45309;
  background: #fef3c7;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.menu-divider {
  height: 1rpx;
  background: #f3f4f6;
  margin: 0 26rpx;
}

.logout-wrap {
  padding: 36rpx 28rpx 8rpx;
}

.btn-logout {
  background: #ffffff;
  color: #0f766e;
  border-radius: 18rpx;
  text-align: center;
  padding: 34rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.btn-logout:active {
  background: #f9fafb;
}

.version-text {
  text-align: center;
  font-size: 24rpx;
  color: #d1d5db;
  padding: 24rpx 0;
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.sheet-cancel {
  font-size: 28rpx;
  color: #9ca3af;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.sheet-confirm {
  font-size: 28rpx;
  color: #d1d5db;
  font-weight: 600;
}

.sheet-confirm.active {
  color: #0f766e;
}

.sheet-body {
  padding: 32rpx 40rpx 80rpx;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #111827;
  box-sizing: border-box;
}

.pwd-field {
  margin-bottom: 28rpx;
}

.pwd-label {
  font-size: 26rpx;
  color: #6b7280;
  display: block;
  margin-bottom: 12rpx;
}

.pwd-input {
  width: 100%;
  height: 80rpx;
  background: #f9fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
}

.bind-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.bind-grow {
  flex: 1;
  min-width: 0;
}

.bind-sms {
  flex-shrink: 0;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #0f766e;
  font-weight: 600;
  background: rgba(13, 148, 136, 0.1);
  border-radius: 12rpx;
  margin-bottom: 4rpx;
}

.bind-sms.disabled {
  color: #9ca3af;
  background: #f3f4f6;
}

.menu-icon.phone {
  background: linear-gradient(135deg, #38bdf8, #0ea5e9);
}
