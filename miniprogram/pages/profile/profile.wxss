.page {
  min-height: 100vh;
  background: #F0FDFF;
  padding-bottom: 60rpx;
}

/* ===== 用户信息卡片 ===== */
.user-card {
  background: linear-gradient(135deg, #0891B2, #0369A1);
  padding: 60rpx 40rpx 48rpx;
  display: flex;
  align-items: center;
}
.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  color: #FFFFFF;
  font-size: 44rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  border: 4rpx solid rgba(255,255,255,0.4);
}
.user-info { flex: 1 }
.user-name { font-size: 40rpx; font-weight: 700; color: #FFFFFF; margin-bottom: 8rpx; }
.user-meta { display: flex; align-items: center; gap: 8rpx; }
.user-company { font-size: 26rpx; color: rgba(255,255,255,0.75); }
.user-dot { color: rgba(255,255,255,0.4); }
.user-role {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.2);
  padding: 4rpx 14rpx;
  border-radius: 24rpx;
}
.user-edit { padding: 8rpx; }
.user-edit:active { opacity: 0.7; }

/* ===== 功能菜单 ===== */
.menu-group { padding: 24rpx 32rpx 0; }
.group-title { font-size: 24rpx; color: #9CA3AF; margin-bottom: 12rpx; padding-left: 4rpx; }

.menu-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(8,145,178,0.06);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  min-height: 100rpx;
}
.menu-item:active { background: #F0FDFF; }
.menu-item.disabled { opacity: 0.5; }

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.menu-icon.recharge { background: #FEF9C3; }
.menu-icon.order    { background: #E0F7FA; }
.menu-icon.nickname { background: #EFF6FF; }
.menu-icon.password { background: #F0FDF4; }

.menu-label { flex: 1; font-size: 30rpx; color: #374151; font-weight: 500; }
.menu-arrow { font-size: 44rpx; color: #D1D5DB; line-height: 1; }
.menu-badge {
  font-size: 22rpx;
  color: #D97706;
  background: #FEF3C7;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 500;
}
.menu-divider { height: 1rpx; background: #CFFAFE; margin: 0 28rpx; }

/* ===== 退出登录 ===== */
.logout-wrap { padding: 40rpx 32rpx 8rpx; }
.btn-logout {
  background: #FFFFFF;
  color: #0891B2;
  border-radius: 20rpx;
  text-align: center;
  padding: 36rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(8,145,178,0.06);
}
.btn-logout:active { background: #E0F7FA; }

.version-text { text-align: center; font-size: 24rpx; color: #D1D5DB; padding: 24rpx 0; }

/* ===== Popup Sheet ===== */
.sheet-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 32rpx 40rpx; border-bottom: 1rpx solid #CFFAFE;
}
.sheet-cancel { font-size: 28rpx; color: #9CA3AF; }
.sheet-title  { font-size: 32rpx; font-weight: 700; color: #164E63; }
.sheet-confirm { font-size: 28rpx; color: #D1D5DB; font-weight: 600; }
.sheet-confirm.active { color: #0891B2; }

.sheet-body { padding: 32rpx 40rpx 80rpx; }

.nickname-input {
  width: 100%; height: 88rpx; background: #F0FDFF;
  border: 2rpx solid #CFFAFE; border-radius: 16rpx;
  padding: 0 24rpx; font-size: 30rpx; color: #164E63; box-sizing: border-box;
}

.pwd-field { margin-bottom: 28rpx; }
.pwd-label { font-size: 26rpx; color: #6B7280; display: block; margin-bottom: 12rpx; }
.pwd-input {
  width: 100%; height: 80rpx; background: #F0FDFF;
  border: 2rpx solid #CFFAFE; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; color: #164E63; box-sizing: border-box;
}
