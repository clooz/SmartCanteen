.page {
  min-height: 100vh;
  background: linear-gradient(165deg, #eef1f6 0%, #f0f4f8 40%, #eef6f7 100%);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.toolbar {
  padding: 12rpx 28rpx 0;
  display: flex;
  justify-content: flex-end;
}

.link-orders {
  font-size: 26rpx;
  color: #0f766e;
  font-weight: 600;
}

.ordering-card {
  margin: 0 28rpx 14rpx;
  padding: 18rpx 14rpx 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 18rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 16rpx rgba(15, 23, 42, 0.04);
}

.ordering-card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #6b7280;
  padding: 0 8rpx 12rpx;
  letter-spacing: 1rpx;
}

.ordering-grid {
  display: flex;
  align-items: stretch;
}

.ordering-cell {
  flex: 1;
  min-width: 0;
  padding: 0 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ordering-vr {
  width: 1rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, transparent, #e5e7eb 14%, #e5e7eb 86%, transparent);
  align-self: stretch;
}

.ordering-cell-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.ordering-meal {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  letter-spacing: 0.5rpx;
}

.ordering-pill {
  flex-shrink: 0;
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  line-height: 1.2;
}

.ordering-pill--ok {
  color: #047857;
  background: #d1fae5;
}

.ordering-pill--muted {
  color: #6b7280;
  background: #f3f4f6;
}

.ordering-pill--wait {
  color: #b45309;
  background: #fef3c7;
}

.ordering-pill--bad {
  color: #991b1b;
  background: #fee2e2;
}

.ordering-time {
  font-size: 24rpx;
  font-weight: 600;
  color: #0f766e;
  font-variant-numeric: tabular-nums;
}

.ordering-hint {
  font-size: 20rpx;
  color: #9ca3af;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.empty-area {
  flex: 1;
  padding: 100rpx 48rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #9ca3af;
  line-height: 1.6;
}

.order-blocked {
  margin: 24rpx 0 32rpx;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 18rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  text-align: center;
}

.order-blocked-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #374151;
  line-height: 1.5;
}

.order-blocked-sub {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.55;
}

.meal-tabs {
  margin: 0 28rpx 14rpx;
  display: flex;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 16rpx;
  padding: 5rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  text-align: center;
  padding: 12rpx 8rpx 14rpx;
  font-size: 28rpx;
  color: #6b7280;
  border-radius: 12rpx;
  font-weight: 600;
}

.tab-name {
  line-height: 1.2;
}

.tab-tag {
  font-size: 20rpx;
  font-weight: 600;
  color: #9ca3af;
  line-height: 1.2;
}

.tab-tag--ok {
  color: #047857;
}

.tab-tag--wait {
  color: #0f766e;
}

.tab-tag--end {
  color: #b45309;
}

.tab-tag--off {
  color: #9ca3af;
}

.tab.active {
  background: #fff;
  color: #0f766e;
  box-shadow: 0 1rpx 8rpx rgba(15, 23, 42, 0.06);
}

.tab.active .tab-name {
  color: #0f766e;
}

.meal-single-row {
  margin: 0 28rpx 14rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.meal-single {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.meal-single-tag {
  font-size: 22rpx;
}

.dish-scroll {
  flex: 1;
  min-height: 0;
  padding: 0 28rpx;
  box-sizing: border-box;
}

.dish-row {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 18rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.03);
}

.dish-thumb {
  width: 112rpx;
  height: 112rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.dish-thumb.ph {
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.dish-main {
  flex: 1;
  min-width: 0;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.35;
}

.dish-meta {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

.price {
  color: #0f766e;
  font-weight: 700;
}

.stock {
  color: #9ca3af;
}

.qty-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: rgba(13, 148, 136, 0.1);
  color: #0f766e;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.qty-num {
  min-width: 48rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.remark-block {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  margin-bottom: 20rpx;
}

.remark-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.remark-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.scroll-pad {
  height: 200rpx;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 14rpx 28rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 -4rpx 24rpx rgba(15, 23, 42, 0.04);
}

.footer-sum {
  flex: 1;
  min-width: 0;
}

.sum-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-right: 8rpx;
}

.sum-price {
  font-size: 36rpx;
  font-weight: 800;
  color: #0f766e;
}

.sum-count {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 4rpx;
}

.btn-submit {
  flex-shrink: 0;
  min-width: 220rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 32rpx;
  background: linear-gradient(125deg, #5eead4 0%, #2dd4bf 38%, #14b8a6 72%, #0d9488 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 44rpx;
  border: none;
  margin: 0;
  box-shadow: 0 8rpx 24rpx rgba(13, 148, 136, 0.22);
}

.btn-submit.disabled {
  opacity: 0.45;
  background: #9ca3af;
  box-shadow: none;
}

.btn-submit::after {
  border: none;
}
