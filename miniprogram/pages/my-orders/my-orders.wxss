.page {
  min-height: 100vh;
  height: 100vh;
  background: #F0FDFF;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
}

.head-row {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx 8rpx;
}

.filter-bar {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #E0F7FA;
  box-shadow: 0 2rpx 8rpx rgba(8, 145, 178, 0.06);
}

.filter-bar:active {
  opacity: 0.92;
}

.filter-bar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
}

.filter-bar-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #164E63;
  flex-shrink: 0;
}

.filter-bar-sum {
  font-size: 24rpx;
  color: #64748B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link-quick {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #0891B2;
  font-weight: 600;
  padding: 16rpx 8rpx;
}

.loading-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty {
  flex: 1;
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 40rpx;
  line-height: 1.5;
  padding: 0 16rpx;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 48rpx;
  background: #0891B2;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.list {
  flex: 1;
  min-height: 0;
  padding: 8rpx 24rpx 0;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E0F7FA;
}

.card-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.no {
  font-size: 24rpx;
  color: #64748B;
  font-family: monospace;
  flex: 1;
  min-width: 0;
  word-break: break-all;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.tag.meal {
  background: #E0F7FA;
  color: #0891B2;
}

.tag.status {
  background: #F1F5F9;
  color: #475569;
}

.tag.status-pending { background: #FEF3C7; color: #B45309; }
.tag.status-confirmed { background: #DBEAFE; color: #1D4ED8; }
.tag.status-ready { background: #D1FAE5; color: #047857; }
.tag.status-done { background: #DCFCE7; color: #166534; }
.tag.status-cancelled { background: #F3F4F6; color: #64748B; }

.card-mid {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.amt {
  font-size: 34rpx;
  font-weight: 800;
  color: #0891B2;
}

.time {
  font-size: 24rpx;
  color: #94A3B8;
}

.remark {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.4;
}

.list-pad {
  height: 40rpx;
}

.popup-inner {
  padding: 24rpx 32rpx 32rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.popup-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164E63;
}

.popup-close {
  padding: 8rpx;
}

.popup-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #64748B;
}

.meta-no {
  word-break: break-all;
  flex: 1;
  min-width: 0;
}

.meta-tag {
  background: #E0F7FA;
  color: #0891B2;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.meta-st {
  font-weight: 600;
  color: #164E63;
}

.line-items {
  border-top: 1rpx solid #EEF2F7;
  padding-top: 16rpx;
}

.li-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #334155;
}

.li-name {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.li-sub {
  color: #64748B;
  font-weight: 600;
}

.popup-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEF2F7;
  font-size: 28rpx;
  color: #64748B;
}

.popup-sum {
  font-size: 36rpx;
  font-weight: 800;
  color: #0891B2;
}

.popup-rm {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748B;
}

.btn-cancel {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #DC2626;
  border: 2rpx solid #FECACA;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel::after {
  border: none;
}

/* 筛选底部面板（与充值记录页风格一致） */
.sheet {
  padding: 8rpx 0 calc(24rpx + env(safe-area-inset-bottom));
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #164e63;
}

.sheet-head-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.sheet-link {
  font-size: 28rpx;
  color: #64748b;
}

.sheet-done {
  font-size: 28rpx;
  font-weight: 700;
  color: #0891b2;
}

.sheet-section {
  padding: 8rpx 0 16rpx;
}

.sheet-sec-title {
  display: block;
  padding: 16rpx 32rpx 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
  letter-spacing: 2rpx;
}

.sheet-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #334155;
  border-bottom: 1rpx solid #f8fafc;
}

.sheet-row--on {
  color: #0e7490;
  font-weight: 600;
}

.sheet-row:active {
  background: #f8fafc;
}
