.page {
  min-height: 100vh;
  height: 100vh;
  background: linear-gradient(165deg, #eef1f6 0%, #f0f4f8 40%, #eef6f7 100%);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
}

.head-row {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 28rpx 6rpx;
}

.filter-bar {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 22rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.filter-bar:active {
  opacity: 0.92;
}

.filter-bar-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
}

.filter-bar-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  flex-shrink: 0;
}

.filter-bar-sum {
  font-size: 24rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link-quick {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #0f766e;
  font-weight: 600;
  padding: 16rpx 8rpx;
}

.loading-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty {
  flex: 1;
  padding: 120rpx 48rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 40rpx;
  line-height: 1.5;
  padding: 0 16rpx;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 48rpx;
  background: linear-gradient(125deg, #2dd4bf, #14b8a6, #0d9488);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(13, 148, 136, 0.22);
}

.list {
  flex: 1;
  min-height: 0;
  padding: 6rpx 28rpx 0;
  box-sizing: border-box;
}

.card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 18rpx;
  padding: 22rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.03);
}

.card-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.no {
  font-size: 24rpx;
  color: #6b7280;
  font-family: monospace;
  flex: 1;
  min-width: 0;
  word-break: break-all;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.tag.meal {
  background: rgba(13, 148, 136, 0.1);
  color: #0f766e;
}

.tag.status {
  background: #f3f4f6;
  color: #475569;
}

.tag.status-pending {
  background: #fef3c7;
  color: #b45309;
}
.tag.status-confirmed {
  background: #dbeafe;
  color: #1d4ed8;
}
.tag.status-ready {
  background: #d1fae5;
  color: #047857;
}
.tag.status-done {
  background: #dcfce7;
  color: #166534;
}
.tag.status-cancelled {
  background: #f3f4f6;
  color: #64748b;
}

.card-mid {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.amt {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f766e;
}

.time {
  font-size: 24rpx;
  color: #9ca3af;
}

.remark {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.4;
}

.list-pad {
  height: 40rpx;
}

.popup-inner {
  padding: 24rpx 32rpx 32rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.popup-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.popup-close {
  padding: 8rpx;
}

.popup-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.meta-no {
  word-break: break-all;
  flex: 1;
  min-width: 0;
}

.meta-tag {
  background: rgba(13, 148, 136, 0.1);
  color: #0f766e;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.meta-st {
  font-weight: 600;
  color: #111827;
}

.line-items {
  border-top: 1rpx solid #f3f4f6;
  padding-top: 16rpx;
}

.li-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #374151;
}

.li-name {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.li-sub {
  color: #6b7280;
  font-weight: 600;
}

.popup-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f4f6;
  font-size: 28rpx;
  color: #6b7280;
}

.popup-sum {
  font-size: 36rpx;
  font-weight: 800;
  color: #0f766e;
}

.popup-rm {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.btn-cancel {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #dc2626;
  border: 1rpx solid #fecaca;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-cancel::after {
  border: none;
}

.sheet {
  padding: 8rpx 0 calc(24rpx + env(safe-area-inset-bottom));
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.sheet-head-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.sheet-link {
  font-size: 28rpx;
  color: #6b7280;
}

.sheet-done {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f766e;
}

.sheet-section {
  padding: 8rpx 0 16rpx;
}

.sheet-sec-title {
  display: block;
  padding: 16rpx 32rpx 8rpx;
  font-size: 22rpx;
  color: #9ca3af;
  letter-spacing: 2rpx;
}

.sheet-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #374151;
  border-bottom: 1rpx solid #f9fafb;
}

.sheet-row--on {
  color: #0f766e;
  font-weight: 600;
}

.sheet-row:active {
  background: #f9fafb;
}
