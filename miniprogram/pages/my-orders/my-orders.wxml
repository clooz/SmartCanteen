<view class="page">
  <view class="head-row">
    <view class="filter-bar" bindtap="openFilterSheet">
      <view class="filter-bar-left">
        <van-icon name="filter-o" size="34rpx" color="#0F766E" />
        <text class="filter-bar-label">筛选</text>
        <text class="filter-bar-sum">{{filterSummaryText}}</text>
      </view>
      <van-icon name="arrow-down" size="28rpx" color="#94A3B8" />
    </view>
    <text class="link-quick" bindtap="goOrder">去下单</text>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <van-loading type="spinner" color="#14B8A6" size="48rpx" />
  </view>

  <view wx:elif="{{!orders.length}}" class="empty">
    <view class="empty-title">暂无订单</view>
    <view class="empty-sub">试试调整「筛选」，或先去下单</view>
    <view class="empty-btn" bindtap="goOrder">去下单</view>
  </view>

  <scroll-view wx:else scroll-y class="list" enhanced show-scrollbar="{{false}}" enable-passive>
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="card"
      data-id="{{item.id}}"
      bindtap="showDetail"
    >
      <view class="card-top">
        <text class="no">#{{item.order_no}}</text>
        <text class="tag meal">{{item.mealLabel}}</text>
        <text class="tag status status-{{item.status}}">{{item.statusLabel}}</text>
      </view>
      <view class="card-mid">
        <text class="amt">¥{{item.total_amount}}</text>
        <text class="time">{{item.createdShort}}</text>
      </view>
      <view wx:if="{{item.remark}}" class="remark">备注：{{item.remark}}</view>
    </view>
    <view class="list-pad"></view>
  </scroll-view>

  <van-popup
    show="{{detailOrder}}"
    position="bottom"
    round
    bind:close="closeDetail"
    custom-style="padding-bottom: env(safe-area-inset-bottom);"
  >
    <view wx:if="{{detailOrder}}" class="popup-inner">
      <view class="popup-head">
        <text class="popup-title">订单详情</text>
        <view class="popup-close" bindtap="closeDetail">
          <van-icon name="cross" size="40rpx" color="#94A3B8" />
        </view>
      </view>
      <view class="popup-meta">
        <text class="meta-no">{{detailOrder.order_no}}</text>
        <text class="meta-tag">{{detailOrder.mealLabel}}</text>
        <text class="meta-st">{{detailOrder.statusLabel}}</text>
      </view>
      <view class="line-items">
        <view wx:for="{{detailOrder.items}}" wx:key="id" class="li-row">
          <text class="li-name">{{item.dish_name}} ×{{item.quantity}}</text>
          <text class="li-sub">¥{{item.subtotal}}</text>
        </view>
      </view>
      <view class="popup-total">
        <text>合计</text>
        <text class="popup-sum">¥{{detailOrder.total_amount}}</text>
      </view>
      <view wx:if="{{detailOrder.remark}}" class="popup-rm">备注：{{detailOrder.remark}}</view>
      <button
        wx:if="{{detailOrder.status === 'pending'}}"
        class="btn-cancel"
        bindtap="cancelOrder"
      >取消订单</button>
    </view>
  </van-popup>

  <van-popup
    show="{{showFilterSheet}}"
    position="bottom"
    round
    bind:close="closeFilterSheet"
    custom-style="max-height: 75vh;"
  >
    <view class="sheet">
      <view class="sheet-head">
        <text class="sheet-title">筛选</text>
        <view class="sheet-head-actions">
          <text class="sheet-link" bindtap="resetDraftFilter">重置</text>
          <text class="sheet-done" bindtap="applyFilterFromSheet">完成</text>
        </view>
      </view>

      <view class="sheet-section">
        <text class="sheet-sec-title">订单状态</text>
        <view
          wx:for="{{statusChips}}"
          wx:key="label"
          class="sheet-row {{draftStatus === item.value ? 'sheet-row--on' : ''}}"
          data-value="{{item.value}}"
          bindtap="onDraftStatus"
        >
          <text>{{item.label}}</text>
          <van-icon wx:if="{{draftStatus === item.value}}" name="success" size="36rpx" color="#0F766E" />
        </view>
      </view>

      <view class="sheet-section">
        <text class="sheet-sec-title">餐次</text>
        <view
          wx:for="{{mealChips}}"
          wx:key="label"
          class="sheet-row {{draftMeal === item.value ? 'sheet-row--on' : ''}}"
          data-value="{{item.value}}"
          bindtap="onDraftMeal"
        >
          <text>{{item.label}}</text>
          <van-icon wx:if="{{draftMeal === item.value}}" name="success" size="36rpx" color="#0F766E" />
        </view>
      </view>

      <view class="sheet-section">
        <text class="sheet-sec-title">下单时间</text>
        <view
          wx:for="{{rangeChips}}"
          wx:key="label"
          class="sheet-row {{draftRange === item.value ? 'sheet-row--on' : ''}}"
          data-value="{{item.value}}"
          bindtap="onDraftRange"
        >
          <text>{{item.label}}</text>
          <van-icon wx:if="{{draftRange === item.value}}" name="success" size="36rpx" color="#0F766E" />
        </view>
      </view>
    </view>
  </van-popup>
</view>
