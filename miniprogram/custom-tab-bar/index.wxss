/**
 * 自定义底栏：图标在上、文案在下，与全站 Teal 主色一致
 * 略增高栏位，保证 44px+ 点击热区与留白
 */
.app-tabbar {
  --tabbar-height: 112rpx;
  --tabbar-item-icon-size: 48rpx;
  --tabbar-item-font-size: 22rpx;
  --tabbar-item-line-height: 1.25;
  --tabbar-item-margin-bottom: 6rpx;
  --tabbar-background-color: rgba(255, 255, 255, 0.96);
  background: rgba(255, 255, 255, 0.96) !important;
  border-top: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 -8rpx 32rpx rgba(15, 23, 42, 0.05);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.app-tabbar .van-tabbar-item__text {
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.app-tabbar .van-tabbar-item--active .van-tabbar-item__text {
  font-weight: 600;
}
