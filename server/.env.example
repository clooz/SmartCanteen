# 复制为 .env 后按需修改

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# 协议版本号（与小程序 miniprogram/utils/legal.js 中 LEGAL_VERSION 保持一致）
LEGAL_VERSION=1

# 短信：1=固定验证码（开发/测试），0=走真实短信通道（需自行实现 smsProvider）
SMS_USE_FIXED=1
SMS_FIXED_CODE=123456
SMS_DAILY_LIMIT_PER_TARGET=20

# 邮箱验证码（忘记密码-邮箱）：固定码模式
EMAIL_USE_FIXED=1
EMAIL_FIXED_CODE=123456
